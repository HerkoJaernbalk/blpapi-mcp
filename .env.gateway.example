# Gateway process (internet-facing or DMZ)

# Address of the private worker MCP endpoint
WORKER_MCP_URL=http://127.0.0.1:8080/mcp

# Gateway listener
MCP_GATEWAY_HOST=0.0.0.0
MCP_GATEWAY_PORT=8443
MCP_GATEWAY_LOG_LEVEL=info

# Auth
# Comma-separated bearer tokens accepted by the gateway.
MCP_GATEWAY_TOKENS=replace-with-long-random-token

# For local testing only. Keep false in production.
MCP_GATEWAY_ALLOW_UNAUTH=false

# Policy
MCP_GATEWAY_ENABLE_HIGH_RISK_TOOLS=false
MCP_GATEWAY_EXTRA_ALLOWED_TOOLS=

# Argument and payload limits
MCP_GATEWAY_TIMEOUT_SEC=120
MCP_GATEWAY_MAX_REQUEST_BYTES=200000
MCP_GATEWAY_MAX_STRING_LEN=5000
MCP_GATEWAY_MAX_ARRAY_ITEMS=200
MCP_GATEWAY_MAX_OBJECT_KEYS=200
MCP_GATEWAY_MAX_NESTING_DEPTH=12
